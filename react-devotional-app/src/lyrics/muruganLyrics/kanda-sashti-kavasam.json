          "Endranai-aalum eraga selva",
          "Maindhan vendum vara-magizhindhu-udhavum",
          "Laalaa laalaa laalaa vesamum",
          "Leelaa leelaa leelaa vinodhan-endru"
        ]
      },
      "meaning": ""
    },
    {
      "order": 15,
      "type": "verse",
      "verseNo": 14,
      "lines": {
        "tamil": [
          "உன்றிருவடியை உறுதியென்றெண்ணும்",
