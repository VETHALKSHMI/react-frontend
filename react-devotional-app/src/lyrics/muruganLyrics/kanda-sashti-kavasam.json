        "english": [
          "Muppuri noolum muththani maarbum",
          "Seppalagu-udaiya thiruvayitrundhiyum",
          "Thuvanda marungil sudarolip pattum",
          "Navarathinam padhiththa narseeraavum",
          "Iruthodai azhagum inaimuzhandhaalum"
        ]
      },
      "meaning": ""
    },
    {
      "order": 12,
      "type": "verse",
      "verseNo": 11,
      "lines": {
        "tamil": [
          "திருவடியதனில் சிலம்பொலி முழங்க",
          "செககண செககண செககண செகண",
          "மொகமொக மொகமொக மொகமொக மொகென",
          "நகநக நகநக நகநக நகென",
          "டிகுகுண டிகுடிகு டிகுகுண டிகுண"
        ],
        "english": [
          "Thiruvadi-adhanil silamboli muzhanga",
          "Segagana segagana segagana segana",
          "Mogamoga mogamoga mogamoga mogena",
          "Naganaga naganaga naganaga nagena",
          "Diguguna digudigu diguguna diguna"
        ]
      },
      "meaning": ""
    },
    {
      "order": 13,
      "type": "verse",
      "verseNo": 12,
      "lines": {
        "tamil": [
          "ரரரர ரரரர ரரரர ரரர",
          "ரிரிரிரி ரிரிரிரி ரிரிரிரி ரிரிரி",
          "டுடுடுடு டுடுடுடு டுடுடுடு டுடுடு",
