{
  "id": "kanda-sashti-kavasam",
  "godId": "murugan",
  "category": "kavasam",
  "title": {
    "tamil": "கந்த சஷ்டி கவசம்",
    "english": "Kanda Sashti Kavasam"
  },
  "description": {
    "tamil": "இது முருகனின் புகழ்பாடல்.",
    "english": "A powerful devotional hymn dedicated to Lord Murugan."
  },
  "kappu": [
    {
      "kappuTitle": {
        "tamil": "நேரிசை வெண்பா",
        "english": "Nerisai Venba"
      },

      "lines": {
        "tamil": [
          "துதிப்போர்க்கு வல்வினைபோம் துன்பம் போம் நெஞ்சில்",
          "பதிப்போர்க்குச் செல்வம் பலித்துக் கதித்து ஓங்கும்",
          "நிஷ்டையுங் கைகூடும் நிமலர் அருள் கந்தர்",
          "சஷ்டி கவசந் தனை"
        ],
        "english": [
          "Thuthipporkku valvinai pom thunbam pom nenjil",
          "Pathipporkkuch selvam paliththu kathiththu ongum",
          "Nishtaiyum kaikoodum Nimalar arul Kandar",
          "Sashti Kavasam thanai"
        ]
      }
    }
  ],

  "lyrics": [
    {
      "order": 1,
      "type": "section",
      "title": {
        "tamil": "குறள் வெண்பா (காப்பு)",
        "english": "Kural Venba (Kaappu)"
      }
    },
    {
      "order": 2,
      "type": "verse",
      "verseNo": 1,
      "lines": {
        "tamil": ["அமரர் இடர்தீர அமரம் புரிந்த", "குமரன் அடி நெஞ்சே குறி"],
        "english": [
          "Amarar idartheera amaram purindha",
          "Kumaran adi nenje kuri"
        ]
      },
      "meaning": ""
    },
    {
      "order": 3,
      "type": "verse",
      "verseNo": 2,
      "lines": {
        "tamil": [
          "சஷ்டியை நோக்கச் சரவணபவனார்",
          "சிஷ்டருக்குத் தவும் செங்கதிர் வேலோன்",
          "பாதமிரண்டில் பன்மணிச் சதங்கை",
          "கீதம் பாட கிண்கிணி யாட",
          "மையல் நடனஞ்செய்யும் மயில்வாகனனார்"
        ],
        "english": [
          "Sashtiyai nokka saravana bavanar",
          "Sishtarku uthavum sengathir velon",
          "Paadham irandil panmani sathangai",
          "Geetham paada kinkini aada",
          "Maiyal nadanam seiyum mayil vaagananar"
        ]
      },
      "meaning": ""
    },
    {
      "order": 4,
      "type": "verse",
      "verseNo": 3,
      "lines": {
        "tamil": [
          "கையில் வேலால் எனைக் காக்கவென்று வந்து",
          "வரவர வேலாயுதனார் வருக",
          "வருக வருக மயிலோன் வருக",
          "இந்திரன் முதலா எண்திசை போற்ற",
          "மந்திர வடிவேல் வருக வருக"
        ],
        "english": [
          "Kaiyil velaal enaikkaakka vendru vandhu",
          "Vara vara velaayudhanaar varuga",
          "Varuga varuga mayilon varuga",
          "Indhiran mudhala endhisai potra",
          "Mandhira vadivel varuga varuga"
        ]
      },
      "meaning": ""
    },
    {
      "order": 5,
      "type": "verse",
      "verseNo": 4,
      "lines": {
        "tamil": [
          "வாசவன் மருகா வருக வருக",
          "நேசக் குறமகள் நினைவோன் வருக",
          "ஆறுமுகம் படைத்த ஐயா வருக",
          "நீறிடும் வேலவன் நித்தம் வருக",
          "சிரகிரி வேலவன் சீக்கிரம் வருக"
        ],
        "english": [
          "Vaasavan marugaa varuga varuga",
          "Nesa kuramagal ninaivon varuga",
          "Aarumugam padaitha aiyaa varuga",
          "Neeridum velavan nitham varuga",
          "Siragiri velavan seekkiram varuga"
        ]
      },
      "meaning": ""
    },
    {
      "order": 6,
      "type": "verse",
      "verseNo": 5,
      "lines": {
        "tamil": [
          "சரவணபவனார் சடுதியில் வருக",
          "ரஹண பவச ரரரர ரரர",
          "ரிஹண பவச ரிரிரிரி ரிரிரி",
          "விணபவ சரவண வீரா நமோ நம",
          "நிபவ சரவண நிறநிற நிறென"
        ],
        "english": [
          "Saravana bavanar sadudhiyil varuga",
          "Rahana bavasa rararara rarara",
          "Rihana bavasa riririri ririri",
          "Vinabava saravana veera namo nama",
          "Nibava saravana niranira nirena"
        ]
      },
      "meaning": ""
    },
    {
      "order": 7,
      "type": "verse",
      "verseNo": 6,
      "lines": {
        "tamil": [
          "வசர ஹணப வருக வருக",
          "அசுரர் குடிகெடுத்த ஐயா வருக",
          "என்னை ஆளும் இளையோன் கையில்",
          "பன்னிரண்டு ஆயுதம் பாச அங்குசமும்",
          "பரந்த விழிகள் பன்னிரண்டிலங்க"
        ],
        "english": [
          "Vasara hanaba varuga varuga",
          "Asurar kudi kedutha aiyaa varuga",
          "Ennai aalum ilaiyon kaiyil",
          "Pannirendu aayudham paasa angusamum",
          "Parandha vizhigal pannirendilanga"
        ]
      },
      "meaning": ""
    },
    {
      "order": 8,
      "type": "verse",
      "verseNo": 7,
      "lines": {
        "tamil": [
          "விரைந்தெனைக் காக்க வேலோன் வருக",
          "ஐயும் கிலியும் அடைவுடன் செளவும்",
          "உய்யொளி செளவும் உயிரையுங் கிலியும்",
          "கிலியுஞ் செளவும் கிளரொளியையும்",
          "நிலை பெற்றென்முன் நித்தமும் ஒளிரும்"
        ],
        "english": [
          "iraindhenaik kaakka velon varuga",
          "Aiyum kiliyum adaivudan saumum",
          "Uyyoli saumum uyiraiyung kiliyum",
          "Kiliyunje saumum kilaroliyaiyum",
          "Nilai petrenmun nithamum olirum"
        ]
      },
      "meaning": ""
    },
    {
      "order": 9,
      "type": "verse",
      "verseNo": 8,
      "lines": {
        "tamil": [
          "சண்முகம் நீயும் தனியொளி யொவ்வும்",
          "குண்டலியாம் சிவகுகன் தினம் வருக",
          "ஆறுமுகமும் அணிமுடி ஆறும்",
          "நீறிடு நெற்றியும் நீண்ட புருவமும்",
          "பன்னிரு கண்ணும் பவளச் செவ்வாயும்"
        ],
        "english": [
          "Shanmugam neeyum thaniyoli yavvum",
          "Kundaliyaam sivagugan dhinam varuga",
          "Aarumugamum animudi aarum",
          "Neeridu netriyum neenda puruvamum",
          "Panniru kannum pavala chevvaayum"
        ]
      },
      "meaning": ""
    },
    {
      "order": 10,
      "type": "verse",
      "verseNo": 9,
      "lines": {
        "tamil": [
          "நன்னெறி நெற்றியில் நவமணிச் சுட்டியும்",
          "ஈராறு செவியில் இலகு குண்டலமும்",
          "ஆறிரு திண்புயத் தழகிய மார்பில்",
          "பல் பூஷணமும் பதக்கமும் தரித்து",
          "நன்மணி பூண்ட நவரத்ன மாலையும்"
        ],
        "english": [
          "Nanneri netriyil navamani chutiyum",
          "Eeraaru seviyil ilagu kundalamum",
          "Aariru thinbuyath azhagiya maarbil",
          "Pal pooshanamum padhakkamum dharithu",
          "Nanmani poonda navarathna maalaiyum"
        ]
      },
      "meaning": ""
    },
    {
      "order": 11,
      "type": "verse",
      "verseNo": 10,
      "lines": {
        "tamil": [
          "முப்புரி நூலும் முத்தணி மார்பும்",
          "செப்பழகுடைய திருவயிறுந்தியும்",
          "துவண்ட மருங்கில் சுடரொளிப் பட்டும்",
          "நவரத்தினம் பதித்த நற்சீராவும்",
          "இருதொடை அழகும் இணைமுழந்தாளும்"
