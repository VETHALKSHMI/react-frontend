        "english": [
          "Rararara rararara rararara rarara",
          "Riririri riririri riririri ririri",
          "Dudududu dudududu dudududu dududu",
          "Dagudagu digudigu dangu dingugu",
          "Vindhu vindhu mayilon vindhu"
        ]
      },
      "meaning": ""
    },
    {
      "order": 14,
      "type": "verse",
      "verseNo": 13,
      "lines": {
        "tamil": [
          "முந்து முந்து முருகவேள் முந்து",
